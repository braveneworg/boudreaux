    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/sharp": "^0.31.1",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.28",
    "input-otp": "^1.4.2",
    "lru-cache": "^11.2.7",
    "lucide-react": "^0.544.0",
    "mongodb": "^7.0.0",
    "music-metadata": "^11.11.2",
    "next": "^16.1.7",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "node-taglib-sharp": "^6.0.1",
    "nodemailer": "^7.0.13",
    "react": "19.2.4",
    "react-day-picker": "^9.11.3",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-hook-form": "^7.63.0",
    "react-image-crop": "^11.0.10",
    "react-resizable-panels": "^3.0.6",
    "react-share": "^5.3.0",
    "react-turnstile": "^1.1.5",
    "recharts": "^2.15.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.3.1",
    "unique-username-generator": "^1.5.1",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "video.js": "^8.23.8",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudfront": "^3.658.1",
    "@eslint/eslintrc": "^3.3.5",
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/eslint-plugin-jsx-a11y": "~6.10.1",
    "@types/eslint-plugin-security": "~3.0.1",
    "@types/eslint-plugin-tailwindcss": "~3.17.0",
    "@types/jsdom": "~27.0.0",
    "@types/mime": "^4.0.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^6.4.23",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.14",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.2.4",
    "eslint": "^9",
    "eslint-config-next": "^16.1.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^9.1.7",
    "jose": "^6.1.3",
    "jsdom": "26.0.0",
    "lint-staged": "^16.2.7",
    "magicast": "^0.3.5",
    "mime": "^4.0.7",
    "prettier": "^3.8.1",
    "prisma": "^6.0.1",
    "shadcn": "^3.4.2",
    "tailwindcss": "^4",
    "tsc-files": "^1.1.4",
    "tsx": "^4.19.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.2",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "tsc-files --noEmit types/next-auth.d.ts types/vitest.d.ts",
      "eslint --config eslint.config.mjs --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "c12>magicast": "^0.3.5",
      "@auth/core>nodemailer": "^7.0.7",
      "typescript-eslint": "^8.58.0",
      "@typescript-eslint/utils": "^8.58.0",
      "@typescript-eslint/typescript-estree": "^8.58.0",
      "@typescript-eslint/tsconfig-utils": "^8.58.0",
      "@typescript-eslint/project-service": "^8.58.0"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msw",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
