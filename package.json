  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "tsc-files --noEmit types/vitest.d.ts",
      "eslint --config eslint.config.mjs --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "^24.18.0",
    "pnpm": "^11.15.0"
  },
