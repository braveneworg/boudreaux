{
  "name": "boudreaux",
  "version": "4.237.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings 0 --fix",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "seed": "tsx prisma/seed.ts",
    "stripe": "stripe listen --forward-to http://localhost:3000/api/stripe/webhook",
    "test": "vitest --reporter=dot --silent",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:check": "vitest run --coverage && pnpm exec tsx scripts/check-coverage-regression.ts",
    "test:shard": "vitest run --reporter=blob --reporter=default --coverage --coverage.thresholds.lines=0 --coverage.thresholds.functions=0 --coverage.thresholds.branches=0 --coverage.thresholds.statements=0",
    "test:merge": "vitest --merge-reports .vitest-reports --coverage",
    "test:no-css": "mv postcss.config.mjs postcss.config.mjs.bak && vitest run && mv postcss.config.mjs.bak postcss.config.mjs",
    "test:e2e": "playwright test",
    "mongo:dump": "pnpm exec tsx scripts/mongo-backup.ts dump",
    "mongo:restore": "pnpm exec tsx scripts/mongo-backup.ts restore",
    "s3:backup": "pnpm exec tsx scripts/s3-backup.ts backup",
    "s3:restore": "pnpm exec tsx scripts/s3-backup.ts restore",
    "s3:list": "pnpm exec tsx scripts/s3-backup.ts list",
    "s3:upload": "pnpm exec tsx scripts/s3-backup.ts upload",
    "s3:cache-headers": "pnpm exec tsx scripts/s3-apply-cache-headers.ts",
    "s3:lifecycle": "pnpm exec tsx scripts/s3-apply-lifecycle.ts",
    "images:upload": "pnpm exec tsx scripts/upload-images.ts",
    "images:generate-variants": "pnpm exec tsx scripts/generate-image-variants.ts",
    "images:convert-to-webp": "pnpm exec tsx scripts/convert-images-to-webp.ts",
    "images:cleanup-orphans": "pnpm exec tsx scripts/cleanup-orphan-images.ts",
    "pwa:generate-icons": "pnpm exec tsx scripts/generate-pwa-icons.ts",
    "backfill:coverart": "pnpm exec tsx scripts/backfill-coverart-urls.ts",
    "docker:build:website": "docker build -t ghcr.io/braveneworg/boudreaux/website .",
    "docker:push:website": "docker push ghcr.io/braveneworg/boudreaux/website",
    "docker:build:nginx": "docker build -t ghcr.io/braveneworg/boudreaux/nginx .",
    "docker:push:nginx": "docker push ghcr.io/braveneworg/boudreaux/nginx",
    "docker:publish:website": "pnpm run docker:build:website && pnpm run docker:push:website",
    "docker:publish:nginx": "pnpm run docker:build:nginx && pnpm run docker:push:nginx",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report e2e/playwright-report",
    "e2e:install": "playwright install chromium",
    "e2e:docker:up": "docker compose -f docker-compose.e2e.yml up -d --wait",
    "e2e:docker:down": "docker compose -f docker-compose.e2e.yml down -v",
    "e2e:ci": "playwright test --shard=$SHARD_INDEX/$SHARD_TOTAL",
    "e2e:merge": "playwright merge-reports --reporter=html ./blob-report",
    "typecheck": "tsc --noEmit",
    "check:query-plans": "pnpm exec tsx scripts/check-query-plans.ts",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "stripe:forward": "stripe listen --forward-to http://localhost:3000/api/stripe/webhook"
  },
  "prisma": {
    "seed": "pnpm exec tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1071.0",
