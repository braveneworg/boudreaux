    "react-hook-form": "^7.78.0",
    "react-image-crop": "^11.0.10",
    "react-resizable-panels": "^3.0.6",
    "react-share": "^5.3.0",
    "react-turnstile": "^1.1.5",
    "recharts": "^3.8.1",
