%% Frontend architecture — Next.js 16 App Router (React 19)
flowchart TB
    User([User / Browser])

    subgraph Browser["Browser runtime"]
        direction TB
        SW["Service Worker<br/>(PWA / offline)"]
        ClientComps["Client Components<br/>('use client')<br/>players · chat · forms"]
        Providers["Providers<br/>QueryClient · SessionProvider · ThemeProvider"]
        Hooks["TanStack Query hooks<br/>useInfiniteReleasesQuery · useInfiniteToursQuery · useInfiniteChatMessagesQuery"]
        RHF["React Hook Form + Zod<br/>zodResolver · field components"]
        Pusher["Pusher client<br/>(real-time chat)"]
    end

    subgraph Server["Server (Next.js)"]
        direction TB
        RSC["Server Components<br/>layout · page (default render)"]
        Hydration["HydrationBoundary<br/>dehydrated query cache (SSR)"]
        Actions["Server Actions<br/>('use server' mutations)"]
        Routes["API Route Handlers<br/>(GET queries · webhooks)"]
    end

    User --> SW
    User --> RSC
    RSC --> Hydration
    Hydration --> Providers
    Providers --> ClientComps
    ClientComps --> Hooks
    ClientComps --> RHF
    ClientComps --> Pusher
    Hooks -->|"fetch + AbortSignal"| Routes
    RHF -->|"submit"| Actions
    Pusher -->|"subscribe events"| ClientComps

    classDef plain fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000;
    classDef group fill:#f0f0f0,stroke:#000000,stroke-width:1px,color:#000000;
    class User,SW,ClientComps,Providers,Hooks,RHF,Pusher,RSC,Hydration,Actions,Routes plain;
