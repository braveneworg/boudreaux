%% External integrations & deployment infrastructure
flowchart TB
    subgraph Edge["Edge / delivery"]
        direction TB
        NGINX["NGINX reverse proxy<br/>TLS · X-Forwarded-For"]
        CF["CloudFront CDN<br/>signed URLs (24h)"]
    end

    subgraph App["Application container"]
        direction TB
        Next["Next.js server<br/>(standalone, Docker)"]
    end

    subgraph Data["Data & storage"]
        direction TB
        Mongo[("MongoDB<br/>(Prisma)")]
        S3[("AWS S3<br/>audio + images")]
    end

    subgraph Third["Third-party services"]
        direction TB
        Stripe["Stripe<br/>PWYW checkout + webhook"]
        SES["AWS SES<br/>transactional email"]
        PusherSvc["Pusher<br/>real-time chat"]
    end

    subgraph Obs["Observability"]
        direction TB
        Alloy["Grafana Alloy"]
        Loki["Loki (log store)"]
        Grafana["Grafana (dashboards)"]
    end

    Browser([Browser]) --> NGINX
    Browser --> CF
    NGINX --> Next
    CF --> S3
    Next --> Mongo
    Next -->|"presigned PUT/GET"| S3
    Next -->|"create session"| Stripe
    Stripe -->|"webhook"| Next
    Next --> SES
    Next --> PusherSvc
    PusherSvc --> Browser
    Next -->|"JSON logs (stdout)"| Alloy
    Alloy --> Loki
    Loki --> Grafana

    classDef plain fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000;
    class NGINX,CF,Next,Mongo,S3,Stripe,SES,PusherSvc,Alloy,Loki,Grafana,Browser plain;
