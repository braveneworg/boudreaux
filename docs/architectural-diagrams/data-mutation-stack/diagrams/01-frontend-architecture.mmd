%% Frontend architecture — RHF forms, mutation hooks, query hooks
flowchart TB
    subgraph Server["Server Components (default)"]
        direction LR
        Page["Page / Layout<br/>app/**/page.tsx"]
        SSR["Server-side prefetch<br/>service / repo (direct)"]
    end

    subgraph Client["Client Components ('use client')"]
        direction LR
        Form["RHF Form<br/>useForm + zodResolver(Zod)"]
        FieldComps["Reusable fields<br/>components/forms/fields"]
        MutHooks["useMutation hooks<br/>hooks/mutations/*"]
        QueryHooks["useEntityQuery hooks<br/>TanStack Query"]
    end

    subgraph Contracts["Client data contracts"]
        direction LR
        Keys["query-keys.ts<br/>stable, typed keys"]
        Parse["fetch + Zod parseResponse<br/>forwards AbortSignal"]
    end

    Action[["Server Action<br/>'use server'"]]
    Route[["API Route Handler<br/>GET / PATCH"]]

    Page --> Form
    Page --> QueryHooks
    Form --> FieldComps
    Form -->|"submit: create / delete"| MutHooks
    Form -->|"reads detail / list"| QueryHooks
    MutHooks -->|"mutationFn"| Action
    QueryHooks -->|"queryFn (GET)"| Route
    QueryHooks --> Keys
    QueryHooks --> Parse
    MutHooks -->|"onSuccess invalidateQueries"| Keys
    Keys -. "invalidation triggers refetch" .-> QueryHooks

    classDef plain fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000;
    class Page,SSR,Form,FieldComps,MutHooks,QueryHooks,Keys,Parse,Action,Route plain;
