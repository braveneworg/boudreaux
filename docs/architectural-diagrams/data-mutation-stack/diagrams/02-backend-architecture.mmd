%% Backend architecture — mutation / query path through the layers
flowchart TB
    subgraph Entry["Entry layer"]
        direction LR
        Action["Server Action<br/>'use server' + 'server-only'<br/>lib/actions"]
        Route["API Route Handler<br/>app/api/**/route.ts"]
        Runner["runAdminEntityAction<br/>shared single-id runner"]
    end

    subgraph Guard["Cross-cutting guards"]
        direction LR
        Auth["requireRole / withAdmin<br/>session + role gate"]
        Zod["Zod validation<br/>lib/validation"]
        Side["logSecurityEvent<br/>+ revalidatePath"]
    end

    Service["Service (static class)<br/>ServiceResponse(T) · caching<br/>Prisma error classification<br/>lib/services"]

    subgraph DataAccess["Data access"]
        direction LR
        Repo["Repository<br/>Prisma queries only<br/>lib/repositories"]
        Prisma["Prisma Client"]
        Mongo[("MongoDB")]
    end

    Result["Result contracts<br/>FormState · AdminActionResult · ServiceResponse(T)"]

    Action --> Auth
    Route --> Auth
    Action --> Zod
    Route --> Zod
    Action --> Runner
    Runner --> Auth
    Action --> Service
    Route --> Service
    Runner --> Service
    Service --> Repo
    Repo --> Prisma
    Prisma --> Mongo
    Service --> Side
    Runner --> Side
    Service -. "returns" .-> Result
    Runner -. "returns" .-> Result

    classDef plain fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000;
    class Action,Route,Runner,Auth,Zod,Side,Service,Repo,Prisma,Mongo,Result plain;
