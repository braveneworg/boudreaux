%% Sequence — admin entity action (delete / publish) via runAdminEntityAction
sequenceDiagram
    autonumber
    actor U as Admin
    participant UI as Admin UI (client)
    participant H as useDelete Mutation
    participant A as Thin action (config)
    participant RN as runAdminEntityAction
    participant G as requireRole admin
    participant S as Service.perform(id)
    participant R as Repository
    participant DB as Prisma / MongoDB
    participant Q as TanStack Query cache

    U->>UI: Confirm delete / publish
    UI->>H: deleteAsync(id)
    H->>A: mutationFn(id)
    A->>RN: runAdminEntityAction(config)
    RN->>G: admin gate
    alt unauthorized
        RN-->>H: AdminActionResult(success false, Unauthorized)
    else authorized
        RN->>RN: isValidObjectId(id)
        RN->>S: perform(id)
        S->>R: delete / publish (id)
        R->>DB: prisma update / delete
        DB-->>R: ok
        R-->>S: success
        S-->>RN: ServiceResponse(success)
        RN->>RN: logSecurityEvent + revalidatePath
        RN-->>A: AdminActionResult(success)
        A-->>H: AdminActionResult(success)
        H->>Q: onSuccess invalidateQueries
        Q-->>UI: list refetch (API route)
        UI-->>U: toast.success
    end
