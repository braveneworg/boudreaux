%% User workflow — admin content management lifecycle
flowchart TB
    Start(["Admin opens /admin"]) --> List["Entity DataView<br/>TanStack Query list"]
    List -->|"New"| CreateForm["RHF Create Form<br/>zodResolver"]
    List -->|"Edit"| EditForm["RHF Edit Form<br/>zodResolver"]
    List -->|"Publish / Delete"| RowAction["Row action<br/>useMutation hook"]

    CreateForm -->|"Server Action returns FormState"| Decide{"Success?"}
    EditForm -->|"PATCH API route (JSON)"| Decide
    RowAction -->|"Server Action returns AdminActionResult"| Decide

    Decide -->|"No"| Err["toast.error<br/>field / general errors"]
    Err --> List
    Decide -->|"Yes"| Inval["invalidateQueries<br/>+ revalidatePath"]
    Inval --> Refetch["List refetches<br/>fresh data"]
    Refetch --> List

    classDef plain fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000;
    class Start,List,CreateForm,EditForm,RowAction,Decide,Err,Inval,Refetch plain;
