NEXT_APP_WEBSITE_IMAGE=ghcr.io/braveneworg/boudreaux/website
NEXT_APP_NGINX_IMAGE=ghcr.io/braveneworg/boudreaux/nginx
REGISTRY="ghcr.io"
PERSONAL_ACCESS_TOKEN="get-this-from-github-settings"

# Database
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority"

# Authentication
AUTH_SECRET="generate-a-random-32+-character-secret-here"
NEXTAUTH_SECRET="generate-a-random-32+-character-secret-here"
NEXTAUTH_URL="http://localhost:3000"

NGINX_SERVER_NAME="your top-level domain here, e.g. example.com"

# # OAuth Providers
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email Configuration (for magic link authentication)
EMAIL_SERVER_HOST="smtp-east.example.com"
EMAIL_SERVER_PORT=25
EMAIL_SERVER_USER="your-email@example.com"
EMAIL_SERVER_PASSWORD="your-email-password"
EMAIL_FROM="noreply@yourapp.com"

# Cloudflare Turnstile (CAPTCHA)
# Production: replace with real keys from dash.cloudflare.com
# Development: the test keys below always pass and require no Cloudflare account
NEXT_PUBLIC_CLOUDFLARE_SITE_KEY="your-site-key"
NEXT_PUBLIC_CLOUDFLARE_TEST_SITE_KEY="1x00000000000000000000AA"
# Server-side secret for verifying Turnstile tokens (required for checkout)
# @see https://developers.cloudflare.com/turnstile/troubleshooting/testing/
CLOUDFLARE_SECRET="1x0000000000000000000000000000000AA"

# CDN Configuration (for client-side asset URLs)
NEXT_PUBLIC_CDN_DOMAIN="https://cdn.fakefourrecords.com"

# AWS S3 (for CDN sync)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET="your-bucket-name"
CDN_DOMAIN="cdn.yourdomain.com"
CLOUDFRONT_DISTRIBUTION_ID="your-distribution-id"

# Application
NODE_ENV="development"
NEXT_TELEMETRY_DISABLED="1"

AUTH_URL="http://localhost:3000"

ADMIN_FIRST_NAME="admin-first-name"
ADMIN_SURNAME="admin-sur-name"
ADMIN_EMAIL="admin@example.com"
ADMIN_PHONE="123-456-7890"

SECONDARY_ADMIN_FIRST_NAME="secondary-admin-first-name"
SECONDARY_ADMIN_SURNAME="secondary-admin-sur-name"
SECONDARY_ADMIN_EMAIL="secondary-admin@example.com"
SECONDARY_ADMIN_PHONE="123-456-7890"

TERTIARY_ADMIN_FIRST_NAME="tertiary-admin-first-name"
TERTIARY_ADMIN_SURNAME="tertiary-admin-sur-name"
TERTIARY_ADMIN_EMAIL="tertiary-admin@example.com"
TERTIARY_ADMIN_PHONE="123-456-7890"

# Change this to your production URL when deploying
NEXT_PUBLIC_HOST_NAME="http://localhost:3000"

# Stripe (subscription payments)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (generated by: npm run stripe:seed)
NEXT_PUBLIC_STRIPE_PRICE_MINIMUM=""
NEXT_PUBLIC_STRIPE_PRICE_EXTRA=""
NEXT_PUBLIC_STRIPE_PRICE_EXTRA_EXTRA=""
