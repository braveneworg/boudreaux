NEXT_APP_WEBSITE_IMAGE=ghcr.io/braveneworg/boudreaux/website
NEXT_APP_NGINX_IMAGE=ghcr.io/braveneworg/boudreaux/nginx
REGISTRY="ghcr.io"
PERSONAL_ACCESS_TOKEN="get-this-from-github-settings"

# Database
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority"

# Authentication (better-auth reads AUTH_SECRET + AUTH_URL; AUTH_URL is set below)
# AUTH_SECRET must be at least 32 characters.
AUTH_SECRET="generate-a-random-32+-character-secret-here"

# Operational kill switch for new signups (optional, NOT a secret — do not add
# to GitHub Actions secrets). Set to "true" to pause account creation: unknown
# emails at /signin are refused (new users must use /signup); unset/false keeps
# signups open. Read at startup — toggling requires a server restart.
# AUTH_DISABLE_SIGNUP=true

NGINX_SERVER_NAME="your top-level domain here, e.g. example.com"

# OAuth / Social Providers
# Redirect URI for all social providers (register in each provider's developer console):
#   <AUTH_URL>/api/auth/callback/<provider>
# Providers are only enabled when BOTH clientId and clientSecret are set.
#
# Google — https://console.cloud.google.com
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
#
# Facebook — https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID="your-facebook-client-id"
FACEBOOK_CLIENT_SECRET="your-facebook-client-secret"
#
# X (Twitter) — https://developer.twitter.com/en/portal/dashboard
# Note: X does not reliably return an email address. Accounts signed in via X
# cannot be auto-linked to an existing account by email; users must link
# manually from their profile (Task 7).
TWITTER_CLIENT_ID="your-twitter-client-id"
TWITTER_CLIENT_SECRET="your-twitter-client-secret"
#
# Apple — https://developer.apple.com/account/resources/authkeys/list
# APPLE_CLIENT_SECRET must be a signed JWT (ES256). Generate it with
# src/lib/auth/apple-client-secret.ts using the keys below, or supply a
# pre-generated JWT. Rotate before the 6-month expiry or sign-in will fail.
APPLE_CLIENT_ID="com.example.yourapp.service-id"
# Generate this JWT with: pnpm exec tsx -e "import {generateAppleClientSecret} from
#   './src/lib/auth/apple-client-secret'; (generate and print)"
APPLE_CLIENT_SECRET="generate-with-apple-client-secret-util-see-comment-above"
APPLE_APP_BUNDLE_IDENTIFIER="com.example.yourapp"
# Used with apple-client-secret.ts to generate a fresh APPLE_CLIENT_SECRET:
APPLE_TEAM_ID="<10-char-apple-team-id>"
APPLE_KEY_ID="XXXXXXXXXX"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<contents of AuthKey_XXXXXXXXXX.p8>\n-----END PRIVATE KEY-----"

# Email Configuration (for magic link authentication)
EMAIL_SERVER_HOST="smtp-east.example.com"
EMAIL_SERVER_PORT=25
EMAIL_SERVER_USER="your-email@example.com"
EMAIL_SERVER_PASSWORD="your-email-password"
EMAIL_FROM="noreply@yourapp.com"

# Cloudflare Turnstile (CAPTCHA)
# Production: replace with real keys from dash.cloudflare.com
# Development: the test keys below always pass and require no Cloudflare account
NEXT_PUBLIC_CLOUDFLARE_SITE_KEY="your-site-key"
NEXT_PUBLIC_CLOUDFLARE_TEST_SITE_KEY="1x00000000000000000000AA"
# Server-side secret for verifying Turnstile tokens (required for checkout)
# @see https://developers.cloudflare.com/turnstile/troubleshooting/testing/
CLOUDFLARE_SECRET="1x0000000000000000000000000000000AA"

# CDN Configuration (for client-side asset URLs)
NEXT_PUBLIC_CDN_DOMAIN="https://cdn.fakefourrecords.com"

# AWS S3 (for CDN sync and digital format storage)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET="your-bucket-name"
# AWS S3 Bucket for digital format uploads (feature 004-release-digital-formats)
AWS_S3_BUCKET_NAME="your-bucket-name"
CDN_DOMAIN="cdn.yourdomain.com"
CLOUDFRONT_DISTRIBUTION_ID="your-distribution-id"

# AI artist bio generation (bio-generator Lambda)
# Name of the deployed Lambda the app invokes; required by env validation.
# Read back from the SAM stack output after deploy (see docs/instructions).
BIO_GENERATOR_LAMBDA_NAME="fakefour-bio-generator"
# Set to "true" for local dev / E2E to skip AWS + Gemini and use the deterministic
# fixture instead of invoking the Lambda. Leave unset/false in production.
BIO_GENERATOR_FAKE="true"

# Application
NODE_ENV="development"
NEXT_TELEMETRY_DISABLED="1"

AUTH_URL="http://localhost:3000"

ADMIN_FIRST_NAME="admin-first-name"
ADMIN_SURNAME="admin-sur-name"
ADMIN_EMAIL="admin@example.com"
ADMIN_PHONE="123-456-7890"

SECONDARY_ADMIN_FIRST_NAME="secondary-admin-first-name"
SECONDARY_ADMIN_SURNAME="secondary-admin-sur-name"
SECONDARY_ADMIN_EMAIL="secondary-admin@example.com"
SECONDARY_ADMIN_PHONE="123-456-7890"

TERTIARY_ADMIN_FIRST_NAME="tertiary-admin-first-name"
TERTIARY_ADMIN_SURNAME="tertiary-admin-sur-name"
TERTIARY_ADMIN_EMAIL="tertiary-admin@example.com"
TERTIARY_ADMIN_PHONE="123-456-7890"

# Change this to your production URL when deploying
NEXT_PUBLIC_HOST_NAME="http://localhost:3000"

# Stripe (subscription payments)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (generated by: npm run stripe:seed)
NEXT_PUBLIC_STRIPE_PRICE_MINIMUM=""

# Stripe PWYW Purchase (003-stripe-pwyw-purchase)
# Comma-separated Stripe webhook IP CIDR ranges — update when Stripe announces changes
# Current ranges: https://stripe.com/docs/ips#webhook-ip-addresses
STRIPE_WEBHOOK_IP_RANGES="54.187.174.169/32,54.187.205.235/32,54.187.126.231/32,54.241.31.99/32,54.241.31.102/32,54.241.31.104/32"
# Base URL used in purchase confirmation email download links
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# SKIP_STRIPE_IP_CHECK=true  # ← ONLY in .env.local for local Stripe CLI dev; NEVER in production
NEXT_PUBLIC_DISABLE_QUERY_CACHE=true

# Live Chat (009-live-chat)
# Pusher Channels (Sandbox plan is free, dashboard at https://dashboard.pusher.com)
# `key` + `cluster` are duplicated as NEXT_PUBLIC_* so the browser SDK can read them.
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="mt1"

# Upstash Redis (REST API; free tier at https://console.upstash.com)
# Used for the chat rate-limit sliding window.
UPSTASH_REDIS_REST_URL="https://your-database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# SMS (010-chat-abuse-reporting)
# Provider selection. Defaults to "noop" so local dev and tests never
# accidentally hit AWS. Set to "sns" in production once the AWS SNS
# sandbox-exit + Toll-Free registration are approved.
SMS_PROVIDER="noop"
# Registered Toll-Free origination number in E.164 format (e.g. +18885551234).
# Required when SMS_PROVIDER=sns; ignored otherwise.
SNS_SMS_ORIGINATION_NUMBER=""
CLOUDFRONT_PRIVATE_KEY_BASE64="your-cloudfront-private-key-base64"
CLOUDFRONT_KEY_PAIR_ID="some-key-pair-id"
# Used for GitHub API calls to create secrets from using gh cli.
# Must have admin scope for your org.
SECRETS_ADMIN_PAT="your-github-pat-with-admin-scope-for-your-org"

# --- Structured logging (winston) ---
# Colorized human-readable server logs in `pnpm dev` (quiet when false/unset)
SHOW_DEV_LOGS=false
# Override the log level (debug|info|warn|error). Prod default: info; dev: warn
# LOG_LEVEL=info
# Comma-separated module names that log debug regardless of LOG_LEVEL
# LOG_DEBUG_MODULES=PRESIGNED_URLS,CHAT
# Grafana admin login for the self-hosted log dashboards (prod: GitHub secret)
# GRAFANA_ADMIN_PASSWORD=
# Prisma slow-query warning threshold in ms (default 200)
# SLOW_QUERY_MS=200
