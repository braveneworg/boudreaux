#!/bin/sh
# Husky invokes this hook with `sh -e`, so any non-zero command aborts.
# Disable -e for the diagnostic prelude; the rest of the script handles
# its own exit codes explicitly.
set +e

# Log file for diagnostics (failures during `git push` can swallow hook stderr).
log_file="${TMPDIR:-/tmp}/husky-pre-push.log"
: > "$log_file"

# Names the step currently running so a failure can report *what* failed even
# before the full log is read. Updated as the hook progresses.
stage="startup"

# Drain pre-push stdin (git sends "<local ref> <local sha> <remote ref>
# <remote sha>" lines) so child processes don't inherit it.
if [ ! -t 0 ]; then
  cat > /dev/null 2>&1 || true
fi
exec </dev/null

# When invoked by `git push`, git exports GIT_* env vars that can confuse
# child git commands (fetch, rev-parse, diff). Unset them so internal git
# calls behave like a normal CLI invocation.
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_PREFIX GIT_OBJECT_DIRECTORY 2>/dev/null
unset GIT_ALTERNATE_OBJECT_DIRECTORIES GIT_QUARANTINE_PATH 2>/dev/null
unset GIT_INTERNAL_GETTEXT_SH_SCHEME GIT_REFLOG_ACTION GIT_EDITOR 2>/dev/null

# Preserve the ORIGINAL stderr on fd 3 *before* we redirect our own output to
# the log file. git relays a hook's stderr to whatever launched the push
# (terminal, VS Code, a GUI client); after the redirect below our fd 2 points
# at the log instead, so the cleanup trap surfaces failures by writing to fd 3.
exec 3>&2

# Redirect all output to the log file; tail it to /dev/tty when one is
# available so progress is visible live during an interactive CLI push.
exec >>"$log_file" 2>&1
tty_shown=0
if [ -e /dev/tty ] && { : >>/dev/tty; } 2>/dev/null; then
  tail -f "$log_file" >/dev/tty 2>/dev/null &
  tail_pid=$!
  tty_shown=1
fi

# Single cleanup path for every exit. Stops the live tail and, on failure,
# surfaces the diagnostics on the original stderr (fd 3) so the reason is
# visible even when there is NO TTY — e.g. pushing from the VS Code Source
# Control panel or a GUI client, where the live tail never ran and git
# otherwise only shows its own generic "failed to push some refs".
cleanup() {
  rc=$?
  if [ -n "${tail_pid:-}" ]; then
    # Let the tail flush its final lines before we kill it on failure.
    [ "$rc" -ne 0 ] && sleep 1
    kill "$tail_pid" 2>/dev/null
  fi
  if [ "$rc" -ne 0 ]; then
    {
      echo ""
      echo "❌ pre-push hook failed during: $stage (exit code $rc)"
      echo "   Full log: $log_file"
      # When the output was already streamed to a TTY, don't repeat the whole
      # log — just the headline above. Otherwise replay it so non-TTY clients
      # (VS Code / GUI) get the actual reason, not just a generic git error.
      if [ "$tty_shown" -eq 0 ]; then
        echo "   ----------------------- hook output -----------------------"
        sed 's/^/   | /' "$log_file" 2>/dev/null
        echo "   -----------------------------------------------------------"
      fi
    } >&3 2>/dev/null
  fi
  exit $rc
}
# shellcheck disable=SC2064
trap cleanup EXIT INT TERM

echo ""
echo "===== pre-push hook started at $(date) ====="

# Prevent pushing directly to main or master branches
stage="branch protection"
branch_name=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch_name" = "main" ] || [ "$branch_name" = "master" ]; then
  echo "🚫 You are on the '$branch_name' branch. Pushing directly to this branch is not allowed."
  exit 1
fi

# Resolve the branch's configured upstream (e.g. "origin/feature-x"). If the
# branch has no upstream yet (first push), fall back to comparing against
# origin/main so first-push branches still get the same safety checks.
#
# Note: on modern git, when no upstream is configured, `rev-parse` exits 128
# AND prints the literal string '@{u}' to stdout. Gate on the exit code so we
# don't capture that literal as if it were a real ref.
stage="upstream resolution"
if upstream_ref=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null); then
  :
else
  upstream_ref=""
fi
if [ -z "$upstream_ref" ]; then
  echo "ℹ️  No upstream configured for '$branch_name' — comparing against 'origin/main'."
  has_upstream=0
  sync_ref="origin/main"
  sync_remote="origin"
  sync_branch="main"
else
  has_upstream=1
  sync_ref="$upstream_ref"
  sync_remote=${upstream_ref%%/*}
  sync_branch=${upstream_ref#*/}
fi

# Skip if there's nothing to push (no commits ahead of the sync ref).
# Use rev-list to count commits, not diff (which compares trees and misses
# merge commits that don't change file content relative to the ref).
commits_ahead=$(git rev-list --count "$sync_ref"..HEAD 2>/dev/null || echo "unknown")
if [ "$commits_ahead" = "0" ]; then
  echo "Nothing to push, skipping pre-push checks."
  exit 0
fi

# Block pushing WIP / fixup! / squash! commits — these should be rebased away
# before review. Match against the subject line of each commit ahead of the
# sync ref.
stage="WIP/fixup commit scan"
wip_subjects=$(git log "$sync_ref"..HEAD --pretty=%s | grep -iE '^(wip([: ]|$)|fixup!|squash!)' || true)
if [ -n "$wip_subjects" ]; then
  echo "🚫 Refusing to push: WIP / fixup! / squash! commits present:"
  printf '   - %s\n' "$wip_subjects"
  echo ""
  echo "   Rebase to clean these up:  git rebase -i $sync_ref --autosquash"
  exit 1
fi

# Fetch the sync ref so the comparison below is against the latest remote
# state. For first-push branches this fetches origin/main; for tracked
# branches it fetches the actual upstream (avoids false "behind" results
# for non-main upstreams).
stage="fetch $sync_ref"
if ! git fetch "$sync_remote" "$sync_branch" --quiet; then
  # A fetch failure is usually a network/auth problem — but it can also mean
  # the upstream branch was DELETED on the remote (commonly: it was merged and
  # the remote branch tidied up). Tell the two apart with ls-remote, whose
  # --exit-code returns exactly 2 when the remote is reachable but has no such
  # ref, versus any other non-zero for a connection/auth failure.
  upstream_deleted=0
  if [ "$has_upstream" = "1" ]; then
    git ls-remote --exit-code "$sync_remote" "refs/heads/$sync_branch" >/dev/null 2>&1
    [ "$?" -eq 2 ] && upstream_deleted=1
  fi

  if [ "$upstream_deleted" = "1" ]; then
    # The branch we track no longer exists remotely, so there's nothing to be
    # "behind" — push to re-create it. Keep the safety checks by falling back
    # to comparing against origin/main, exactly like a brand-new branch.
    echo "ℹ️  Upstream '$sync_ref' no longer exists on '$sync_remote' (branch deleted)."
    echo "   Falling back to 'origin/main' and pushing to re-create the branch."
    has_upstream=0
    sync_ref="origin/main"
    sync_remote="origin"
    sync_branch="main"
    stage="fetch $sync_ref"
    if ! git fetch "$sync_remote" "$sync_branch" --quiet; then
      echo "❌ Failed to fetch latest changes from $sync_ref. Please check your network connection and try again."
      exit 1
    fi
  else
    echo "❌ Failed to fetch latest changes from $sync_ref. Please check your network connection and try again."
    exit 1
  fi
fi

# If local branch is genuinely behind the sync ref, prevent push and tell
# the user to merge it in first. For new branches this means merging
# origin/main; for tracked branches it means rebasing onto the upstream.
stage="up-to-date check against $sync_ref"
if ! git merge-base --is-ancestor "$sync_ref" HEAD; then
  if [ "$has_upstream" = "1" ]; then
    echo "🚫 Your local branch is behind '$sync_ref'."
    echo "   Run: git pull --rebase $sync_remote $sync_branch"
  else
    echo "🚫 Your branch '$branch_name' is missing commits from '$sync_ref'."
    echo "   Merge the latest main in before pushing:"
    echo "   git merge $sync_ref"
    echo "   (or: git pull --rebase $sync_remote $sync_branch)"
  fi
  exit 1
fi

# Diff base for change detection is the same ref we just synced against.
diff_base="$sync_ref"

# Check if any .ts or .tsx files changed compared to the diff base
TS_CHANGED=$(git diff --name-only "$diff_base"..HEAD -- '*.ts' '*.tsx' 2>/dev/null | head -1)

if [ -z "$TS_CHANGED" ]; then
  echo "📦 No .ts or .tsx files changed — skipping type-check, lint, and tests."
  echo "🚀 Pushing changes..."
  exit 0
fi

echo "🔍 Running TypeScript type-check before push..."
stage="TypeScript type-check (pnpm exec tsc --noEmit)"

# Run TypeScript type-check on the entire project
pnpm exec tsc --noEmit

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ TypeScript type-check failed. Please fix type errors before pushing."
  echo "   Run 'pnpm exec tsc --noEmit' to see all errors."
  exit 1
fi

echo "✅ TypeScript type-check passed"

echo ""
echo "🔎 Running ESLint before push..."
stage="ESLint (pnpm run lint)"

pnpm run lint

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ ESLint found errors or warnings. Please fix them before pushing."
  echo "   Run 'pnpm run lint' to see all issues."
  exit 1
fi

echo "✅ ESLint passed"

echo ""
echo "🧪 Running tests before push..."
stage="tests + coverage (pnpm run test:coverage:check)"

# Suppress console output during tests to reduce verbosity
SUPPRESS_CONSOLE=1 pnpm run test:coverage:check --reporter=dot --silent

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Tests failed. Please fix failing tests before pushing."
  echo "   Run 'pnpm run test' to see all failures."
  exit 1
fi

echo "✅ All tests passed"
echo "🚀 Pushing changes..."

exit 0
