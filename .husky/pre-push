#!/bin/sh

# Prevent pushing directly to main or master branches
branch_name=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch_name" = "main" ] || [ "$branch_name" = "master" ]; then
  echo "🚫 You are on the '$branch_name' branch. Pushing directly to this branch is not allowed."
  exit 1
fi

# Resolve the branch's configured upstream (e.g. "origin/feature-x"). If the
# branch has no upstream yet (first push), fall back to comparing against
# origin/main so first-push branches still get the same safety checks.
upstream_ref=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)
if [ -z "$upstream_ref" ]; then
  echo "ℹ️  No upstream configured for '$branch_name' — comparing against 'origin/main'."
  has_upstream=0
  sync_ref="origin/main"
  sync_remote="origin"
  sync_branch="main"
else
  has_upstream=1
  sync_ref="$upstream_ref"
  sync_remote=${upstream_ref%%/*}
  sync_branch=${upstream_ref#*/}
fi

# Skip if there's nothing to push (no commits ahead of the sync ref).
# Use rev-list to count commits, not diff (which compares trees and misses
# merge commits that don't change file content relative to the ref).
commits_ahead=$(git rev-list --count "$sync_ref"..HEAD 2>/dev/null || echo "unknown")
if [ "$commits_ahead" = "0" ]; then
  echo "Nothing to push, skipping pre-push checks."
  exit 0
fi

# Fetch the sync ref so the comparison below is against the latest remote
# state. For first-push branches this fetches origin/main; for tracked
# branches it fetches the actual upstream (avoids false "behind" results
# for non-main upstreams).
if ! git fetch "$sync_remote" "$sync_branch" --quiet; then
  echo "❌ Failed to fetch latest changes from $sync_ref. Please check your network connection and try again."
  exit 1
fi

# If local branch is genuinely behind the sync ref, prevent push and tell
# the user to merge it in first. For new branches this means merging
# origin/main; for tracked branches it means rebasing onto the upstream.
if ! git merge-base --is-ancestor "$sync_ref" HEAD; then
  if [ "$has_upstream" = "1" ]; then
    echo "🚫 Your local branch is behind '$sync_ref'."
    echo "   Run: git pull --rebase $sync_remote $sync_branch"
  else
    echo "🚫 Your branch '$branch_name' is missing commits from '$sync_ref'."
    echo "   Merge the latest main in before pushing:"
    echo "   git merge $sync_ref"
    echo "   (or: git pull --rebase $sync_remote $sync_branch)"
  fi
  exit 1
fi

# Diff base for change detection is the same ref we just synced against.
diff_base="$sync_ref"

# Check if any .ts or .tsx files changed compared to the diff base
TS_CHANGED=$(git diff --name-only "$diff_base"..HEAD -- '*.ts' '*.tsx' 2>/dev/null | head -1)

if [ -z "$TS_CHANGED" ]; then
  echo "📦 No .ts or .tsx files changed — skipping type-check, lint, and tests."
  echo "🚀 Pushing changes..."
  exit 0
fi

echo "🔍 Running TypeScript type-check before push..."

# Run TypeScript type-check on the entire project
pnpm exec tsc --noEmit

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ TypeScript type-check failed. Please fix type errors before pushing."
  echo "   Run 'pnpm exec tsc --noEmit' to see all errors."
  exit 1
fi

echo "✅ TypeScript type-check passed"

echo ""
echo "🔎 Running ESLint before push..."

pnpm run lint

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ ESLint found errors or warnings. Please fix them before pushing."
  echo "   Run 'pnpm run lint' to see all issues."
  exit 1
fi

echo "✅ ESLint passed"

echo ""
echo "🧪 Running tests before push..."

# Suppress console output during tests to reduce verbosity
# SUPPRESS_CONSOLE=1 pnpm run test:coverage:check --reporter=dot --silent
pnpm run test:coverage:check --reporter=dot

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Tests failed. Please fix failing tests before pushing."
  echo "   Run 'pnpm run test' to see all failures."
  exit 1
fi

echo "✅ All tests passed"
echo "🚀 Pushing changes..."
