#!/bin/sh

# Skip if there's nothing to push (local ref is up to date with remote)
if ! git diff --quiet HEAD @{u} 2>/dev/null; then
  : # there are commits to push, continue
else
  echo "Nothing to push, skipping pre-push checks."
  exit 0
fi

# Prevent pushing directly to main or master branches
branch_name=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch_name" = "main" ] || [ "$branch_name" = "master" ]; then
  echo "🚫 You are on the '$branch_name' branch. Pushing directly to this branch is not allowed."
  exit 1
fi

# Fetch latest changes from remote to ensure we're pushing on top of the latest code
git fetch origin main --quiet

if [ $? -ne 0 ]; then
  echo "❌ Failed to fetch latest changes from remote. Please check your network connection and try again."
  exit 1
fi

# If local branch is behind remote, prevent push to avoid conflicts
if ! git merge-base --is-ancestor @{u} HEAD; then
  echo "🚫 Your local branch is behind the remote branch."
  git checkout main
  git pull --rebase
  git checkout "$branch_name"
  git merge main --no-ff --quiet
  if [ $? -ne 0 ]; then
    echo "❌ Failed to pull or merge latest changes from remote. Please resolve any conflicts and try pushing again."
    exit 1
  fi
  echo "✅ Your local branch is now up to date with remote. Please try pushing again"
  exit 0
fi

echo "🔍 Running TypeScript type-check before push..."

# Run TypeScript type-check on the entire project
pnpm exec tsc --noEmit

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ TypeScript type-check failed. Please fix type errors before pushing."
  echo "   Run 'pnpm exec tsc --noEmit' to see all errors."
  exit 1
fi

echo "✅ TypeScript type-check passed"

echo ""
echo "🔎 Running ESLint before push..."

pnpm run lint

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ ESLint found errors or warnings. Please fix them before pushing."
  echo "   Run 'pnpm run lint' to see all issues."
  exit 1
fi

echo "✅ ESLint passed"

echo ""
echo "🧪 Running tests before push..."

# Run tests excluding the unrelated failing SSR test
# Suppress console output during tests to reduce verbosity
SUPPRESS_CONSOLE=1 pnpm run test:coverage:check --reporter=dot --silent

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Tests failed. Please fix failing tests before pushing."
  echo "   Run 'pnpm run test' to see all failures."
  exit 1
fi

echo "✅ All tests passed"
echo "🚀 Pushing changes..."
