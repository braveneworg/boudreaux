{
  "annotations": { "list": [] },
  "description": "Request latency derived from the durationMs field emitted by withLogging and logAction. Note: 2xx responses are sampled 1-in-20 (4xx/5xx always logged), so percentiles are estimates weighted toward errors under low traffic.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Overall request latency percentiles from sampled durationMs (ms).",
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.50, {container=\"website\"} | json | unwrap durationMs | __error__=`` [5m])",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.95, {container=\"website\"} | json | unwrap durationMs | __error__=`` [5m])",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.99, {container=\"website\"} | json | unwrap durationMs | __error__=`` [5m])",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Request latency p50 / p95 / p99 (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "p95 latency per instrumented module (ms).",
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.95, {container=\"website\"} | json | unwrap durationMs | __error__=`` [5m]) by (module)",
          "legendFormat": "{{module}}",
          "refId": "A"
        }
      ],
      "title": "p95 latency by module (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Logged requests per module (sampled for 2xx).",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (module) (count_over_time({container=\"website\"} | json | durationMs != `` [5m]))",
          "legendFormat": "{{module}}",
          "refId": "A"
        }
      ],
      "title": "Logged request rate by module (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Requests slower than 1s — includes requestId for end-to-end correlation.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=\"website\"} | json | durationMs > 1000",
          "refId": "A"
        }
      ],
      "title": "Slow requests (> 1s)",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["boudreaux", "latency"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Boudreaux — Request Latency",
  "uid": "boudreaux-app-latency",
  "version": 1
}
